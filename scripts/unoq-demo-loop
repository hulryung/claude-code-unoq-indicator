#!/bin/bash
# Cycle through Claude Code character states every 5 seconds.
# Stop with: kill $(cat /tmp/unoq-demo.pid)  or  ~/bin/unoq-demo-stop
echo $$ > /tmp/unoq-demo.pid
states=(idle thinking tool done notify error)
trap 'rm -f /tmp/unoq-demo.pid; exit 0' INT TERM
while true; do
    for s in "${states[@]}"; do
        curl -s --max-time 1 -X POST -H 'Content-Type: application/json' \
             -d "{\"state\":\"$s\"}" \
             http://Janie.local:8765/state >/dev/null 2>&1
        echo "$(date +%H:%M:%S) → $s"
        sleep 5
    done
done
